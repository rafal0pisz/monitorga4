# ============================================================
# GA4 Quality Score — Environment Variables
# Skopiuj do .env.local i uzupełnij wartościami
# NIGDY nie commituj .env.local do repo
# ============================================================

# Supabase (nowy projekt, osobny od BetterDocs)
NEXT_PUBLIC_SUPABASE_URL=https://TWOJ_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Aplikacja
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Worker
# Sekret dla Vercel Cron → /api/worker/run (Vercel dokłada go automatycznie
# jako "Authorization: Bearer <CRON_SECRET>" gdy ta zmienna jest ustawiona)
CRON_SECRET=zmien-na-losowy-string-min-32-znaki

# Dev bypass (usuń lub ustaw na false przed deployem)
NEXT_PUBLIC_DEV_BYPASS_AUTH=true

# Admin — e-maile (po przecinku) dopuszczone do /admin/dashboard-app
ADMIN_EMAILS=ty@bettersteps.pl

# Resend (alerty e-mail)
RESEND_API_KEY=re_...
RESEND_FROM=AlertGA4 <reports@alertga4.bettersteps.pl>

# Zbiorczy digest — adres właściciela konta, wysyłany po każdym
# automatycznym (cron) przebiegu. Per-projektowe alerty do klientów
# konfiguruje się osobno, w ustawieniach danego projektu (alert_email).
DIGEST_EMAIL=ty@bettersteps.pl

# Stripe (billing)
# Klucz API i webhook secret — Stripe Dashboard → Developers.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price ID (Stripe Dashboard → Product catalog) — 3 plany × 2 okresy rozliczeniowe
STRIPE_PRICE_INDIVIDUAL_MONTHLY=price_...
STRIPE_PRICE_INDIVIDUAL_YEARLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_AGENCY_MONTHLY=price_...
STRIPE_PRICE_AGENCY_YEARLY=price_...
