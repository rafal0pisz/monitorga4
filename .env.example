# ============================================================
# GA4 Quality Score — Environment Variables
# Skopiuj do .env.local i uzupełnij wartościami
# NIGDY nie commituj .env.local do repo
# ============================================================

# Supabase (nowy projekt, osobny od BetterDocs)
NEXT_PUBLIC_SUPABASE_URL=https://TWOJ_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Aplikacja
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Worker
# Losowy token do autoryzacji Cloud Scheduler → /api/worker/run
WORKER_SECRET_TOKEN=zmien-na-losowy-string-min-32-znaki

# Dev bypass (usuń lub ustaw na false przed deployem)
NEXT_PUBLIC_DEV_BYPASS_AUTH=true

# Resend (alerty e-mail) — dodaj w tygodniu 4
# RESEND_API_KEY=re_...
# RESEND_FROM=monitor@bettersteps.pl
